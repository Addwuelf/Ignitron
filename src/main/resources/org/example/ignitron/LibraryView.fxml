<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Root is a StackPane so the loading overlay can sit on top of the game grid
    while a background scan is running.
-->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.ignitron.controllers.LibraryController">

    <ScrollPane fx:id="scrollPane"
                styleClass="library-scroll"
                fitToWidth="true">
        <FlowPane fx:id="gameGrid"
                  hgap="20" vgap="20"
                  styleClass="game-grid"/>
    </ScrollPane>

    <!-- Shown while a background scan is running, hidden otherwise -->
    <VBox fx:id="loadingOverlay"
          styleClass="loading-overlay"
          alignment="CENTER"
          visible="false" managed="false">
        <ProgressIndicator styleClass="loading-spinner"/>
        <Label text="Scanning for games..." styleClass="picker-count"/>
    </VBox>

</StackPane>
