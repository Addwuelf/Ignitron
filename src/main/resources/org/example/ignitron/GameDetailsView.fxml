<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="900" prefWidth="900"
            style="-fx-background-color: #3a3a3a;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.ignitron.controllers.GameDetailsController">


<!-- Back Button -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 20;">
            <Button onAction="#onBackClicked"
                    style="
            -fx-background-radius: 8;
            -fx-padding: 4 10;
            -fx-background-color: #2d2d2d;
        ">
                <graphic>
                    <Label text="←"
                           style="-fx-font-size: 36px; -fx-text-fill: white;" />
                </graphic>
            </Button>


        </HBox>
    </top>

    <center>
        <!-- your existing VBox content -->
        <VBox alignment="TOP_CENTER" spacing="20">
            <padding>
                <Insets bottom="40" left="40" right="40" top="40" />
            </padding>

            <ImageView fx:id="gameIcon" fitHeight="256" fitWidth="256" preserveRatio="true" />
            <Label fx:id="gameName" style="-fx-font-size: 32px; -fx-font-weight: bold;" />
            <FlowPane fx:id="tagContainer" alignment="CENTER" hgap="10" vgap="10" />

            <VBox alignment="CENTER" spacing="6">
                <Label fx:id="lastPlayedLabel" />
                <Label fx:id="totalPlaytimeLabel" />
                <Label fx:id="installPathLabel" />
            </VBox>

            <Button fx:id="playButton"
                    onAction="#onPlayClicked"
                    text="Play"
                    style="
            -fx-background-color: #3a3a3a;
            -fx-background-radius: 8;
            -fx-font-size: 18px;
            -fx-text-fill: white;
            -fx-padding: 10 40;
        " />

        </VBox>
    </center>

</BorderPane>
