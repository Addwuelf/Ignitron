<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="details-pane"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.ignitron.controllers.GameDetailsController">

    <!-- Back Button Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="details-back-bar">
            <Button onAction="#onBackClicked" styleClass="back-button">
                <graphic>
                    <Label text="←" styleClass="back-arrow" />
                </graphic>
            </Button>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="20">
            <padding>
                <Insets bottom="40" left="40" right="40" top="40" />
            </padding>

            <ImageView fx:id="gameIcon" fitHeight="256" fitWidth="256" preserveRatio="true" />
            <Label fx:id="gameName" styleClass="details-game-name" />
            <FlowPane fx:id="tagContainer" alignment="CENTER" hgap="10" vgap="10" />

            <VBox alignment="CENTER" spacing="6">
                <Label fx:id="lastPlayedLabel" styleClass="details-info-label" />
                <Label fx:id="totalPlaytimeLabel" styleClass="details-info-label" />
                <Label fx:id="installPathLabel" styleClass="details-info-label" />
            </VBox>

            <Button fx:id="playButton"
                    onAction="#onPlayClicked"
                    text="Play"
                    styleClass="details-play-button" />

        </VBox>
    </center>

</BorderPane>
