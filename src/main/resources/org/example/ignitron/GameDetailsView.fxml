<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ignitron.controllers.GameDetailsController"
      spacing="15" style="-fx-padding: 20;">

    <ImageView fx:id="gameIcon" fitWidth="128" fitHeight="128" />

    <Label fx:id="gameName" style="-fx-font-size: 24px; -fx-text-fill: white;" />

    <FlowPane fx:id="tagContainer" hgap="8" vgap="8" />

    <Button text="Play" fx:id="playButton" />

</VBox>


