<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.ignitron.controllers.GameDetailsController"
            prefWidth="900" prefHeight="600">

    <center>
        <VBox spacing="20" alignment="TOP_CENTER">
            <padding>
                <Insets top="40" bottom="40" left="40" right="40"/>
            </padding>

            <!-- Game Icon / Hero -->
            <ImageView fx:id="gameIcon"
                       fitWidth="256"
                       fitHeight="256"
                       preserveRatio="true"
                       smooth="true"
                       style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0, 0, 4);"/>

            <!-- Game Title -->
            <Label fx:id="gameName"
                   style="-fx-font-size: 32px; -fx-font-weight: bold;"/>

            <!-- Tags -->
            <FlowPane fx:id="tagContainer"
                      hgap="10" vgap="10"
                      alignment="CENTER"
                      style="-fx-padding: 10 0 0 0;"/>

            <!-- Metadata Section -->
            <VBox spacing="6" alignment="CENTER">
                <Label fx:id="lastPlayedLabel"
                       text="Last played: Never"
                       style="-fx-font-size: 14px; -fx-text-fill: #888;"/>

                <Label fx:id="totalPlaytimeLabel"
                       text="Total playtime: 0h 0m"
                       style="-fx-font-size: 14px; -fx-text-fill: #888;"/>

                <Label fx:id="installPathLabel"
                       text="Install path: "
                       style="-fx-font-size: 12px; -fx-text-fill: #777;"/>
            </VBox>

            <!-- Play Button -->
            <Button fx:id="playButton"
                    text="Play"
                    onAction="#onPlayClicked"
                    style="-fx-font-size: 18px; -fx-padding: 10 40 10 40; -fx-background-radius: 8;"/>
        </VBox>
    </center>

</BorderPane>




