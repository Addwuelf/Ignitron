<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.ignitron.controllers.MainController">

    <!-- Sidebar -->
    <left>
        <VBox spacing="10" style="-fx-background-color: #1e1e1e; -fx-padding: 20;">
            <Button text="Library" fx:id="libraryButton" />
            <Button text="Settings" fx:id="settingsButton" />
        </VBox>
    </left>

    <!-- Top Bar -->
    <top>
        <HBox spacing="10" style="-fx-background-color: #2a2a2a; -fx-padding: 10;">
            <TextField fx:id="searchField" promptText="Search games..." />
        </HBox>
    </top>

    <!-- Main Content Area -->
    <center>
        <StackPane fx:id="contentArea" />
    </center>

</BorderPane>

