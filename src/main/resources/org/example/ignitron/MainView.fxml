<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.ignitron.controllers.MainController">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <Label text="IGNITRON" styleClass="app-title" />
            <Region styleClass="sidebar-divider" maxWidth="Infinity" />
            <Button text="Library"  fx:id="libraryButton"  styleClass="nav-button" maxWidth="Infinity" onAction="#onLibraryClicked" />
            <Button text="Settings" fx:id="settingsButton" styleClass="nav-button" maxWidth="Infinity" onAction="#onSettingsClicked" />

            <!-- Spacer pushes Scan button to the bottom -->
            <Region styleClass="sidebar-spacer" VBox.vgrow="ALWAYS" />

            <Region styleClass="sidebar-divider" maxWidth="Infinity" />
            <Button text="Scan for Games" fx:id="scanButton" styleClass="nav-button"
                    maxWidth="Infinity" onAction="#onScanClicked" />
        </VBox>
    </left>

    <!-- Top Bar -->
    <top>
        <HBox styleClass="top-bar">
            <TextField fx:id="searchField" promptText="Search games..." styleClass="search-field" HBox.hgrow="ALWAYS" />
            <Button fx:id="starredFilterButton" text="★ Starred"
                    styleClass="starred-filter-button"
                    onAction="#onStarredFilterClicked" />
            <Button fx:id="addGameButton" text="Add Game" styleClass="add-game-button" onAction="#onAddGameClicked" />
        </HBox>
    </top>

    <!-- Main Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #161616;" />
    </center>

</BorderPane>
